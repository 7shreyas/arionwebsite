# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ── Email (Resend) ────────────────────────────────────────────────
# Required for contact form emails to deliver.
# 1. Create a free account at https://resend.com
# 2. Add & verify your domain (arionaisolutions.com)
# 3. Create an API key and paste it here
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Analytics (Plausible) ────────────────────────────────────────
# Optional. Remove this line to disable analytics entirely.
# 1. Create a site at https://plausible.io
# 2. Enter your domain exactly as it appears in Plausible
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=arionaisolutions.com
